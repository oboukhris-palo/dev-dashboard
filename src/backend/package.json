{
    "name": "dev-dashboard-backend",
    "version": "1.0.0",
    "description": "Node.js backend for Dev Dashboard filesystem operations",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "watch": "tsc --watch",
        "clean": "rm -rf dist"
    },
    "keywords": [
        "filesystem",
        "git",
        "scanner"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "express": "^4.18.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.0",
        "nodemon": "^3.0.1",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}