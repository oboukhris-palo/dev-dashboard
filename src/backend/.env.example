# Dev Dashboard Backend Configuration
# Copy this file to .env and customize for your local setup

# Server Port
PORT=3000

# Workspace Paths (comma-separated absolute paths)
# These are the directories that will be scanned for git repositories
# Examples:
#   macOS:   WORKSPACE_PATHS=/Users/YOUR_USERNAME/workspace,/Users/YOUR_USERNAME/Documents/workspace
#   Windows: WORKSPACE_PATHS=C:/Users/YOUR_USERNAME/workspace,C:/Users/YOUR_USERNAME/projects
#   Linux:   WORKSPACE_PATHS=/home/YOUR_USERNAME/workspace,/home/YOUR_USERNAME/projects
WORKSPACE_PATHS=/Users/YOUR_USERNAME/workspace,/Users/YOUR_USERNAME/Documents/workspace

# Exclude Patterns (comma-separated)
# Directories to ignore during scanning
EXCLUDE_PATTERNS=node_modules,.git,dist,build,target,.vscode,.idea,coverage,out,tmp

# Enable debug logging (true/false)
DEBUG=false
